              "role": {
                "en": "preposition + genitive noun (mudaf)",
                "bn": "অব্যয় + সম্বন্ধপদ (মুদাফ)"
              },
              "hl": true
            },
            {
              "ar": "ٱلْفَلَقِ",
              "en": "the daybreak",
              "bn": "ভোর",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            }
          ]
        },
        {
          "ref": "113:2",
          "trans": {
