  "lessons": [
    {
      "id": "read-114-1",
      "unit": "read-114",
      "icon": "📖",
      "title": {
        "en": "Surah an-Nas — word by word",
        "bn": "সূরা আন-নাস — শব্দে শব্দে"
      },
      "concept": {
        "en": "This surah teaches the imperative verb (amr) 'qul' and the genitive construct chain (idafah), where each governed noun takes the kasra ending. It also shows the relative pronoun al-ladhi introducing a clause.",
        "bn": "এই সূরা আদেশসূচক ক্রিয়া (আমর) 'কুল' এবং সম্বন্ধযুক্ত ইদাফা শেখায়, যেখানে প্রতিটি অধীন বিশেষ্য কাসরা গ্রহণ করে। এটি আল-লাযি সম্বন্ধবাচক সর্বনামও দেখায়।"
      },
      "examples": [
        {
          "ref": "114:1",
          "trans": {
            "en": "Say: I seek refuge in the Lord of mankind,",
            "bn": "বলো, আমি আশ্রয় চাই মানুষের রবের কাছে,"
          },
          "note": {
            "en": "'qul' is a command verb; 'bi-rabbi' is a preposition + genitive noun starting an idafah chain with al-nas.",
            "bn": "'কুল' একটি আদেশসূচক ক্রিয়া; 'বিরব্বি' একটি অব্যয় + সম্বন্ধপদ যা আন-নাসের সাথে ইদাফা শুরু করে।"
          },
          "words": [
            {
              "ar": "قُلْ",
              "en": "Say",
              "bn": "বলো",
              "role": {
                "en": "command verb (amr)",
                "bn": "আদেশসূচক ক্রিয়া (আমর)"
              },
              "hl": true
            },
            {
              "ar": "أَعُوذُ",
              "en": "I seek refuge",
              "bn": "আমি আশ্রয় চাই",
              "role": {
                "en": "present-tense verb, 1st person",
                "bn": "বর্তমান কালের ক্রিয়া, উত্তম পুরুষ"
              }
            },
            {
              "ar": "بِرَبِّ",
              "en": "in the Lord of",
              "bn": "রবের কাছে",
              "role": {
                "en": "preposition + genitive noun",
                "bn": "অব্যয় + সম্বন্ধপদ (মাজরুর)"
              },
              "hl": true
            },
            {
              "ar": "ٱلنَّاسِ",
              "en": "mankind",
              "bn": "মানুষের",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            }
          ]
        },
        {
          "ref": "114:2",
          "trans": {
            "en": "the King of mankind,",
            "bn": "মানুষের বাদশাহ,"
          },
          "note": {
            "en": "'malik' is an apposition (badal) to 'rabb', also in the genitive as the second term of a new idafah.",
            "bn": "'মালিক' 'রব্ব'-এর বদল, এটিও নতুন ইদাফার প্রথম পদ হিসেবে সম্বন্ধ অবস্থায়।"
          },
          "words": [
            {
              "ar": "مَلِكِ",
              "en": "King of",
              "bn": "বাদশাহ",
              "role": {
                "en": "genitive noun, apposition (badal)",
                "bn": "সম্বন্ধ বিশেষ্য, বদল"
              },
              "hl": true
            },
            {
              "ar": "ٱلنَّاسِ",
              "en": "mankind",
              "bn": "মানুষের",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            }
          ]
        },
        {
          "ref": "114:3",
          "trans": {
            "en": "the God of mankind,",
            "bn": "মানুষের ইলাহ (উপাস্য),"
          },
          "note": {
            "en": "'ilah' is a further apposition (badal) to 'rabb', again genitive, heading another idafah.",
            "bn": "'ইলাহ' 'রব্ব'-এর আরেকটি বদল, আবার সম্বন্ধ অবস্থায়, আরেকটি ইদাফার শীর্ষ।"
          },
          "words": [
            {
              "ar": "إِلَٰهِ",
              "en": "God of",
              "bn": "ইলাহ",
              "role": {
                "en": "genitive noun, apposition (badal)",
                "bn": "সম্বন্ধ বিশেষ্য, বদল"
              },
              "hl": true
            },
            {
              "ar": "ٱلنَّاسِ",
              "en": "mankind",
              "bn": "মানুষের",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            }
          ]
        },
        {
          "ref": "114:4",
          "trans": {
            "en": "from the evil of the sneaking whisperer,",
            "bn": "সেই কুমন্ত্রণাদাতার অনিষ্ট থেকে যে লুকিয়ে যায়,"
          },
          "note": {
            "en": "'min' governs 'sharr' in the genitive; 'sharr' heads an idafah with 'al-waswas', and 'al-khannas' is its adjective (na't).",
            "bn": "'মিন' 'শার্র'-কে সম্বন্ধ করে; 'শার্র' 'আল-ওয়াসওয়াস'-এর সাথে ইদাফা করে, আর 'আল-খান্নাস' তার বিশেষণ (নাত)।"
          },
          "words": [
            {
              "ar": "مِن",
              "en": "from",
              "bn": "থেকে",
              "role": {
                "en": "preposition (harf jarr)",
                "bn": "অব্যয় (হারফ জার্র)"
              }
            },
            {
              "ar": "شَرِّ",
              "en": "the evil of",
              "bn": "অনিষ্ট",
              "role": {
                "en": "genitive noun (majrur), mudaf",
                "bn": "সম্বন্ধপদ (মাজরুর), মুদাফ"
              },
              "hl": true
            },
            {
              "ar": "ٱلْوَسْوَاسِ",
              "en": "the whisperer",
              "bn": "কুমন্ত্রণাদাতা",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            },
            {
              "ar": "ٱلْخَنَّاسِ",
              "en": "who withdraws",
              "bn": "যে পিছিয়ে লুকায়",
              "role": {
                "en": "adjective (na't)",
                "bn": "বিশেষণ (নাত)"
              }
            }
          ]
        },
        {
          "ref": "114:5",
          "trans": {
            "en": "who whispers into the breasts of mankind,",
            "bn": "যে মানুষের অন্তরে কুমন্ত্রণা দেয়,"
          },
          "note": {
            "en": "'al-ladhi' is a relative pronoun; 'yuwaswisu' is the present-tense verb of its clause; 'fi suduri' is a prepositional phrase in an idafah with al-nas.",
            "bn": "'আল-লাযি' সম্বন্ধবাচক সর্বনাম; 'ইউওয়াসউইসু' তার বাক্যের বর্তমান ক্রিয়া; 'ফি সুদুরি' আন-নাসের সাথে ইদাফাযুক্ত অব্যয়-বাক্যাংশ।"
          },
          "words": [
            {
              "ar": "ٱلَّذِى",
              "en": "who",
              "bn": "যে",
              "role": {
                "en": "relative pronoun (ism mawsul)",
                "bn": "সম্বন্ধবাচক সর্বনাম (ইসম মাউসুল)"
              },
              "hl": true
            },
            {
              "ar": "يُوَسْوِسُ",
              "en": "whispers",
              "bn": "কুমন্ত্রণা দেয়",
              "role": {
                "en": "present-tense verb",
                "bn": "বর্তমান কালের ক্রিয়া"
              }
            },
            {
              "ar": "فِى",
              "en": "in / into",
              "bn": "মধ্যে",
              "role": {
                "en": "preposition (harf jarr)",
                "bn": "অব্যয় (হারফ জার্র)"
              }
            },
            {
              "ar": "صُدُورِ",
              "en": "the breasts of",
              "bn": "অন্তরসমূহ",
              "role": {
                "en": "genitive noun (majrur), mudaf",
                "bn": "সম্বন্ধপদ (মাজরুর), মুদাফ"
              }
            },
            {
              "ar": "ٱلنَّاسِ",
              "en": "mankind",
              "bn": "মানুষের",
              "role": {
                "en": "genitive noun (mudaf ilayh)",
                "bn": "সম্বন্ধ বিশেষ্য (মুদাফ ইলাইহি)"
              }
            }
          ]
        },
        {
          "ref": "114:6",
          "trans": {
            "en": "from among the jinn and mankind.",
            "bn": "জিন ও মানুষের মধ্য থেকে।"
          },
          "note": {
            "en": "'min' governs 'al-jinnah' in the genitive; 'wa-al-nas' is coordinated (ma'tuf) to it by the conjunction wa.",
            "bn": "'মিন' 'আল-জিন্নাহ'-কে সম্বন্ধ করে; 'ওয়া-আন-নাস' 'ওয়া' সংযোজক দিয়ে যুক্ত (মাতুফ)।"
          },
          "words": [
            {
              "ar": "مِنَ",
              "en": "from among",
              "bn": "মধ্য থেকে",
              "role": {
                "en": "preposition (harf jarr)",
                "bn": "অব্যয় (হারফ জার্র)"
              }
            },
            {
              "ar": "ٱلْجِنَّةِ",
              "en": "the jinn",
              "bn": "জিন",
              "role": {
                "en": "genitive noun (majrur)",
                "bn": "সম্বন্ধপদ (মাজরুর)"
              },
              "hl": true
            },
            {
              "ar": "وَٱلنَّاسِ",
              "en": "and mankind",
              "bn": "ও মানুষ",
              "role": {
                "en": "conjunction + coordinated noun (ma'tuf)",
                "bn": "সংযোজক + যুক্ত বিশেষ্য (মাতুফ)"
              }
            }
          ]
        }
      ],
      "practice": {
        "q": {
          "en": "What is the grammatical role of 'qul' in ayah 1?",
          "bn": "১ম আয়াতে 'কুল'-এর ব্যাকরণগত ভূমিকা কী?"
        },
        "options": [
          "Command verb (amr)",
          "Noun",
          "Relative pronoun",
          "Preposition"
        ],
        "answer": 0,
        "explain": {
          "en": "'Qul' is an imperative (amr) verb meaning 'Say', addressed to the Prophet.",
          "bn": "'কুল' একটি আদেশসূচক (আমর) ক্রিয়া, অর্থ 'বলো', নবীকে সম্বোধন করে।"
        }
      }
    },
