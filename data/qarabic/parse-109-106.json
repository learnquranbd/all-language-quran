      "title": {
        "en": "Al-Kafirun: The Declaration (1-3)",
        "bn": "আল-কাফিরূন: ঘোষণা (১-৩)"
      },
      "concept": {
        "en": "The Prophet is commanded to address the disbelievers and declare a clear separation of worship.",
        "bn": "নবীকে কাফিরদের সম্বোধন করে ইবাদতের স্পষ্ট পার্থক্য ঘোষণা করার আদেশ দেওয়া হয়েছে।"
      },
      "examples": [
        {
          "ref": "109:1",
          "trans": {
            "en": "Say, O disbelievers,",
            "bn": "বলুন, হে কাফিরগণ,"
          },
          "note": {
            "en": "The command 'Say' (Qul) opens a direct address to those who reject faith.",
            "bn": "'বলুন' (কুল) আদেশটি বিশ্বাস অস্বীকারকারীদের প্রতি সরাসরি সম্বোধন শুরু করে।"
          },
          "words": [
            {
              "ar": "قُلْ",
              "en": "Say",
              "bn": "বলুন",
              "role": {
                "en": "command verb",
                "bn": "আদেশসূচক ক্রিয়া"
              },
              "hl": true
            },
            {
              "ar": "يَٰٓأَيُّهَا",
              "en": "O",
              "bn": "হে",
              "role": {
                "en": "vocative particle",
                "bn": "সম্বোধন অব্যয়"
              }
            },
            {
              "ar": "ٱلْكَٰفِرُونَ",
              "en": "the disbelievers",
              "bn": "কাফিরগণ",
              "role": {
                "en": "noun (addressed)",
                "bn": "বিশেষ্য (সম্বোধিত)"
              }
            }
          ]
        },
        {
          "ref": "109:2",
          "trans": {
            "en": "I do not worship what you worship,",
            "bn": "আমি ইবাদত করি না যার ইবাদত তোমরা কর,"
          },
          "note": {
            "en": "A negated present-tense verb establishes present rejection of their idols.",
            "bn": "নেতিবাচক বর্তমান ক্রিয়া তাদের মূর্তির বর্তমান প্রত্যাখ্যান প্রতিষ্ঠা করে।"
          },
