      "practice": {
        "q": {
          "en": "What does the command 'Qul' (قُلْ) mean?",
          "bn": "'কুল' (قُلْ) আদেশটির অর্থ কী?"
        },
        "options": [
          "Say",
          "Read",
          "Stand",
          "Listen"
