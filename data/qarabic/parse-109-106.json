              "ar": "وَلَآ",
              "en": "and not",
              "bn": "আর না",
              "role": {
                "en": "conjunction + negation",
                "bn": "সংযোজক + নেতিবাচক"
              }
            },
            {
              "ar": "أَنتُمْ",
              "en": "you",
              "bn": "তোমরা",
              "role": {
                "en": "subject pronoun",
                "bn": "কর্তৃবাচক সর্বনাম"
              }
            },
            {
              "ar": "عَٰبِدُونَ",
              "en": "worshippers",
              "bn": "ইবাদতকারী",
              "role": {
                "en": "active participle (predicate)",
                "bn": "কর্তৃবাচক বিশেষণ (বিধেয়)"
