              "hl": true
            },
            {
              "ar": "مَآ",
              "en": "what",
              "bn": "যা",
              "role": {
                "en": "relative pronoun",
                "bn": "সম্বন্ধবাচক সর্বনাম"
              }
            },
            {
              "ar": "أَعْبُدُ",
              "en": "I worship",
              "bn": "আমি ইবাদত করি",
              "role": {
                "en": "present verb (1st person)",
                "bn": "বর্তমান ক্রিয়া (উত্তম পুরুষ)"
              }
            }
          ]
        }
